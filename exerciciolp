#include <stdio.h>

int main()
{
    int n, i, somap, somai, total;
    float media;

    for (i = 1; i <= 100; i = i + 1)
    {
        printf("Digite um numero: ");
        scanf("%d", &n);
        while (n < 0)
        {
            printf("Digite um numero diferente de zero: ");
            scanf("%d", &n);
        }
    }
    if (n % 2 == 0)
    {
        somap = 0;
        somap = somap + n;
    }
    else if (n % 2 == 1)
    {
        somai = 0;
        somai = somai + n;
    }
    total = total + n;
    media = total / 100;
    printf("A soma dos pares é: %d", somap);
    printf("A soma dos impares é: %d", somai);
    printf("A media e: %f", media);

    return 0;
}